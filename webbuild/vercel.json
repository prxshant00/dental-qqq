{
  "routes": [
    {
      "src": "/(.*)\.(jpg|jpeg|png|gif|svg)",
      "headers": {
        "Cache-Control": "max-age=31536000, public"
      }
    },
    {
      "src": "/api/(.*)",
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/(.*)",
      "headers": {
        "X-Custom-Header": "value"
      }
    }
  ]
}